{
  "name": "hashr",
  "version": "1.1.0-SNAPSHOT",
  "private": true,
  "description": "An easy to use file hashing utility working with multiple algorithms. Powered by React & Material UI, built as a cross-plaform desktop application using Electron.",
  "keywords": [
    "electron",
    "hash",
    "javascript",
    "md4",
    "md5",
    "node",
    "react",
    "ripemd",
    "ripemd160",
    "sha1",
    "sha224",
    "sha256",
    "sha384",
    "sha512",
    "typescript",
    "whirlpool"
  ],
  "homepage": "https://github.com/kobionic/hashr",
  "bugs": {
    "url": "https://github.com/kobionic/hashr/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kobionic/hashr.git"
  },
  "license": "Apache-2.0",
  "author": "Jeremie Rodriguez <contact@jeremierodriguez.com> (https://github.com/jeremiergz)",
  "main": "build/main.js",
  "scripts": {
    "build": "npm-run-all --parallel 'build:web -- --mode production' build:electron",
    "build:desktop": "build --x64 -lw",
    "build:dev": "npm-run-all --parallel 'build:web -- --mode development --watch' 'build:electron -- --watch'",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:web": "webpack --mode production",
    "clean": "rimraf dist",
    "lint": "tslint --project . --format stylish",
    "package": "npm-run-all clean build build:desktop",
    "prepare": "npm run build",
    "start": "electron ."
  },
  "dependencies": {
    "@material-ui/core": "3.6.2",
    "@material-ui/icons": "3.0.1",
    "bytes": "3.0.0",
    "moment": "2.22.2",
    "ms": "2.1.1",
    "react": "16.6.3",
    "react-dom": "16.6.3",
    "react-toastify": "4.4.3"
  },
  "devDependencies": {
    "@kobionic/codestyle-react": "^1.0.1",
    "@types/bytes": "^3.0.0",
    "@types/ms": "^0.7.30",
    "@types/react": "^16.7.13",
    "@types/react-dom": "^16.0.11",
    "@types/react-toastify": "^4.0.1",
    "ajv": "^6.6.1",
    "app-root-path": "^2.1.0",
    "clean-webpack-plugin": "^1.0.0",
    "copy-webpack-plugin": "^4.6.0",
    "css-loader": "^1.0.1",
    "electron": "^3.0.10",
    "electron-builder": "^20.38.2",
    "file-loader": "^2.0.0",
    "html-loader": "^0.5.5",
    "html-webpack-plugin": "^3.2.0",
    "interpolate-html-plugin": "^3.0.0",
    "mini-css-extract-plugin": "^0.5.0",
    "npm-run-all": "^4.1.5",
    "optimize-css-assets-webpack-plugin": "^5.0.1",
    "rimraf": "^2.6.2",
    "source-map-loader": "^0.2.4",
    "ts-loader": "^5.3.1",
    "tslint": "^5.11.0",
    "tslint-react": "^3.6.0",
    "typescript": "^3.2.2",
    "typings-for-css-modules-loader": "^1.7.0",
    "url-loader": "^1.1.2",
    "webpack": "^4.27.1",
    "webpack-cli": "^3.1.2"
  },
  "build": {
    "appId": "com.kobionic.hashr",
    "copyright": "Copyright Ⓒ 2018 KoBionic",
    "productName": "HashR",
    "files": [
      "build/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "linux": {
      "category": "Utility",
      "synopsis": "An easy to use file hashing utility working with multiple algorithms.",
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "snap",
        "tar.gz"
      ]
    },
    "appImage": {
      "systemIntegration": "doNotAsk"
    },
    "deb": {
      "packageCategory": "utils"
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
